[
  {
    "name": "get_mbusa_dealers",
    "description": "Searches for official Mercedes-Benz USA (MBUSA) dealerships based on a provided US zip code.",
    "parameters": {
      "type": "object",
      "properties": {
        "zip_code": {
          "type": "string",
          "description": "The 5-digit United States zip code."
        },
        "start": { "type": "integer", "default": 0 },
        "count": { "type": "integer", "default": 10 }
      },
      "required": ["zip_code"]
    }
  },
  {
    "name": "get_mbusa_inventory",
    "description": "Searches for new Mercedes-Benz vehicle inventory near a specific zip code. Returns vehicle details including image URLs and dealer links. ALWAYS format the output with Markdown links so the user can click the dealer website or view the car image directly.",
    "parameters": {
      "type": "object",
      "properties": {
        "params": {
          "type": "object",
          "properties": {
            "zip": {
              "type": "string",
              "description": "The 5-digit US zip code. Required."
            },
            "dealerId": {
              "type": "string",
              "description": "5-digit dealer code if known."
            },
            "distance": {
              "type": "integer",
              "enum": [10, 25, 50, 100, 200, 500, 1000],
              "description": "Search radius in miles. Omit if there is no distance criteria."
            },
            "minPrice": {
              "type": "integer",
              "description": "Minimum MSRP in dollars."
            },
            "maxPrice": {
              "type": "integer",
              "description": "Maximum MSRP in dollars."
            },
            "bodyStyle": {
              "type": "string",
              "enum": ["CABRDS", "CPE", "SDN", "SUV", "WGN"],
              "description": "CABRDS=Convertibles/Roadsters, CPE=Coupe, SDN=Sedan, SUV=Sports Utility Vehicle, WGN=Wagon."
            },
            "brand": {
              "type": "string",
              "enum": ["AMG", "MAYBACH"]
            },
            "classId": {
              "type": "string",
              "enum": ["C", "CLA", "CLE", "E", "EQB", "EQE", "EQS", "G", "GLA", "GLB", "GLC", "GLE", "GLS", "AMGGT"],
              "description": "The Mercedes-Benz Class."
            },
            "model": {
              "type": "string",
              "enum": [
                "E53EW4", "C43W4", "GLA250W4", "S580V4", "C63W4SE", "CLA35C4", "CLA45C4S", "CLE53A4", "CLE53C4", 
                "AMGEQEV4", "E53ES4", "AMGEQEX4", "AMGEQSV4", "G63W4", "GLA35W4", "GLB35W4", "GLC43C4", "GLC43W4", 
                "GLC63C4E", "GLC63W4E", "GLE53W4", "GLE53C4", "GLE63W4S", "GLE63C4S", "GLS63W4", "GT43C4", "AMGGT43", 
                "GT53C4", "AMGGT55", "GT63C4", "AMGGT63", "AMGGT63X", "GT63C4SE", "AMGGT63E", "S63EV4", "SL43R", 
                "SL55R4", "SL63R4", "SL63ER4", "C300W4", "C300W", "CLA250C4", "CLA250C", "CLA350E4", "CLE300A4", 
                "CLE300C4", "CLE450A4", "E350W4", "CLE450C4", "E350W", "E450S4", "E450W4", "EQB250W", "EQB300W4", 
                "EQB350W4", "EQE350V4", "EQE350X4", "EQE350V", "EQE350X", "EQE500V4", "EQE500X4", "EQS450V4", "EQS450V", 
                "EQS450X", "EQS580V4", "G550W4", "G580W4E", "GLA250W", "GLB250W4", "GLB250W", "GLC300C4", "GLC300W4", 
                "GLC300W", "GLC350E4", "GLE350W4", "GLE350W", "GLE450C4", "GLE450W4", "GLE450E4", "GLE580W4", "GLS450W4", 
                "GLS580W4", "EQS680Z4", "GLS600Z4", "S580Z4", "S680Z4", "SL680Z4", "S500V4", "S580EV4"
              ]
            },
            "exteriorColor": {
              "type": "string",
              "enum": ["BLK", "BLU", "BWN", "GRN", "GRY", "RED", "SLV", "WHT", "YLW", "OTR"],
              "description": "BLK=Black, BLU=Blue, BWN=Brown, GRN=Green, GRY=Grey, RED=Red, SLV=Silver, WHT=White, YLW=Yellow, OTR=Other."
            },
            "interiorColor": {
              "type": "string",
              "enum": ["BGE", "BLK", "BWN", "GRY", "RED", "OTR"],
              "description": "BGE=Beige, BLK=Black, BWN=Brown, GRY=Grey, RED=Red, OTR=Other."
            },
            "year": {
              "type": "integer",
              "enum": [2024, 2025, 2026]
            },
            "highwayFuelEconomy": {
              "type": "string",
              "enum": ["0_19", "20_30", "30_40", "40_1000000"],
              "description": "0_19=Under 20 MPG, 20_30=20-30 MPG, 30_40=30-40 MPG, 40_1000000=40+ MPG."
            },
            "passengerCapacity": {
              "type": "integer",
              "enum": [2, 4, 5, 7]
            },
            "fuelType": {
              "type": "string",
              "enum": ["E", "G", "PH", "PPH"],
              "description": "E=Electric, G=Gasoline, PH=Plugin Hybrid, PPH=Performance Plug-in Hybrid."
            },
            "start": { "type": "integer", "default": 0 },
            "count": { "type": "integer", "default": 12 }
          },
          "required": ["zip"]
        }
      }
    }
  }
]