{
  "skill": "report-expert",
  "name": "报告专家",
  "version": "1.6.0",
  "channel": "stable",
  "updated": "2026-04-14",
  "description": "专业 HTML 报告生成与部署工具。支持 Mermaid 流程图、ECharts/Chart.js 数据可视化、自动目录、滚动进度、图表点击放大（缩放+拖拽）、设计系统 v6.1、部署前强制校验。",
  "author": "传琪",
  "repository": "https://report-expert-skill.pages.dev",
  "env": {
    "CLOUDFLARE_API_TOKEN": {
      "desc": "Cloudflare API Token（远程部署 + 技能 CF 发布共用）",
      "required": false
    }
  },
  "bins": [
    "python3",
    "curl",
    "npx",
    "wrangler",
    "openclaw",
    "clawhub"
  ],
  "capabilities": [
    {
      "id": "report-page",
      "name": "报告页面部署",
      "since": "1.0.0",
      "desc": "将 HTML 内容套用模板生成完整报告页面"
    },
    {
      "id": "external-page",
      "name": "外部页面索引",
      "since": "1.1.0",
      "desc": "支持将外部页面添加到索引"
    },
    {
      "id": "iframe-viewer",
      "name": "iframe 内嵌查看",
      "since": "1.2.0",
      "desc": "外部页面在首页通过 iframe 内嵌打开"
    },
    {
      "id": "design-system",
      "name": "设计系统 v6.1",
      "since": "1.0.0",
      "desc": "底色层级配色、SVG 图标体系、响应式布局"
    },
    {
      "id": "auto-config",
      "name": "部署模式自适应",
      "since": "1.3.1",
      "desc": "从 TOOLS.md 读取部署配置，支持 local/remote 模式"
    },
    {
      "id": "chart-engine",
      "name": "多引擎图表系统",
      "since": "1.5.0",
      "desc": "Mermaid 流程图 + ECharts 数据可视化 + Chart.js，自动缩放限高，点击放大支持缩放拖拽"
    },
    {
      "id": "deploy-guard",
      "name": "部署前强制校验",
      "since": "1.5.0",
      "desc": "自动检测 div 平衡、单框架、无手写 footer、script 位置，不合格拒绝部署"
    }
  ],
  "categories": {
    "research": "深度研究",
